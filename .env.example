# Copy this file to .env and fill in your values

# ── Recall.ai (get from app.recall.ai) ──────────────────
RECALLAI_API_KEY=your_recall_api_key_here
RECALL_REGION=ap-northeast-1

# ── ngrok tunnel URL (update every time ngrok restarts) ─
NGROK_URL=https://xxxx.ngrok-free.app

# ── LLM keys ────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ── Text-to-Speech ───────────────────────────────────────
# Leave SARVAM_API_KEY blank to use free gTTS. Set it to use Sarvam (Indian voices).
# TTS_PROVIDER auto-selects sarvam when a key is present; force with gtts|sarvam.
SARVAM_API_KEY=
TTS_PROVIDER=
SARVAM_MODEL=bulbul:v2
SARVAM_SPEAKER=anushka
SARVAM_LANG=en-IN

# ── Timeouts (seconds) — keep tight to cut Recall bot-runtime cost on no-shows ──
WAITING_ROOM_TIMEOUT=180   # bot leaves the lobby if not admitted (lower = cheaper, less grace for late joins)
NO_SHOW_TIMEOUT=120        # bot leaves if no consent after being admitted
SILENCE_END_SEC=180        # end interview after this much candidate silence
MAX_INTERVIEW_SEC=2700     # 45-min hard cap
SCHEDULED_EXPIRY_MIN=30    # (minutes) scheduled session → no_show if candidate never joined

# ── Proctoring / integrity (post-interview) ─────────────
PROCTORING_ENABLED=true
# Vision (phone / 2nd-person on sparse frames): Gemini first, OpenAI fallback
OPENAI_API_KEY=
# Video sampling cadence (seconds) — larger = cheaper/lighter
PROCTOR_FRAME_SEC=10       # local MediaPipe face-sample interval
PROCTOR_CLOUD_SEC=60       # cloud-vision (phone/2nd-person) interval
PROCTOR_VIDEO_WAIT=20      # attempts to poll for the video URL (×30s)

# ── Gmail SMTP (use App Password, not login password) ────
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Encryption key (generate once, keep secret) ──────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=your_fernet_key_here
